# Copy to agent-input.env and fill the values.
# Keep agent-input.env private. It may contain proxy credentials and relay access details.

# Local router
LOCAL_PROXY_PORT=7890
MIHOMO_API_PORT=9090
NETWORK_SERVICE=Wi-Fi

# Relay host reachable over SSH by the deploying agent.
RELAY_SSH_TARGET=user@relay.example.com
RELAY_SING_BOX_CONFIG_PATH=/etc/sing-box/config.json
RELAY_SING_BOX_SERVICE=sing-box

# Hysteria2 relay inbound.
AI_RELAY_HOST=relay.example.com
AI_RELAY_PORT=443
HY2_PASSWORD=replace-with-strong-random-password
HY2_SNI=example.com
HY2_SKIP_CERT_VERIFY=true
HY2_UP="30 Mbps"
HY2_DOWN="150 Mbps"

# Stable AI egress from the relay.
STABLE_EGRESS_HTTP_HOST=stable-egress.example.com
STABLE_EGRESS_HTTP_PORT=8080
STABLE_EGRESS_HTTP_USERNAME=replace-me
STABLE_EGRESS_HTTP_PASSWORD=replace-me

# Comma-separated suffixes. Do not include private company domains in a public commit.
AI_DOMAINS=anthropic.com,claude.ai,claudeusercontent.com
CORPORATE_DOMAINS=corp.example,internal.example,cdn.corp.example
DIRECT_DOMAINS=example.cn,local-bank.example

# Optional probes used by diagnostics.
GENERAL_EGRESS_PROBE_URL=https://ipinfo.io/ip
AI_ROUTE_PROBE_URL=https://api.anthropic.com/
DOMESTIC_PROBE_URL=https://example.cn/
CORPORATE_PROBE_HOST=internal.example
